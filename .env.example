# =========================================================================
# PlayHub — environment variables
# Copy to .env.local for development; configure same vars in Vercel for prod.
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# =========================================================================

# --- Site identity ------------------------------------------------------
# Public site URL — used for canonical tags, sitemap.xml, OG metadata,
# robots.txt host. MUST be the production origin in prod (no trailing slash).
# Example: https://playhub.com
NEXT_PUBLIC_SITE_URL=https://playhub.example

# --- Search Console -----------------------------------------------------
# Google Search Console verification token (HTML meta tag method).
# 1. Add property at https://search.google.com/search-console
# 2. Pick "HTML tag" verification, copy the content="..." value here.
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Analytics ----------------------------------------------------------
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave empty in dev.
NEXT_PUBLIC_GA_ID=

# --- Ads ----------------------------------------------------------------
# Ad provider toggle: 'stub' | 'adsense' | 'adinplay'.
# Stays 'stub' until Month 2 / AdSense approval.
NEXT_PUBLIC_AD_PROVIDER=stub

# Google AdSense publisher client ID (ca-pub-XXXXXXXXXXXXXXXX).
# Empty = placeholder mode (no AdSense script loaded, dashed ad boxes shown).
# When set AND user accepts cookie consent, the loader script mounts and
# AdPlacement renders real ad units. Per-slot IDs are configured in
# components/AdPlacement.tsx → SLOT_IDS (one entry per slot type).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Clerk (authentication) --------------------------------------------
# Sign up at https://clerk.com → create a "Plixfy" application.
# Enable Email + Google + X/Twitter providers under "User & authentication".
# Copy keys from "API Keys" page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk → Supabase user-sync webhook signing secret.
# Dashboard → Webhooks → "Add Endpoint" → URL: https://yoursite/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted. Copy "Signing Secret".
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# --- Supabase (database) ------------------------------------------------
# Sign up at https://supabase.com → create new project (free tier).
# Settings → API → copy these values.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
# DANGER: service_role bypasses RLS. Server-only, never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# =========================================================================
# Production checklist (when deploying):
#   [ ] NEXT_PUBLIC_SITE_URL set to real https origin
#   [ ] public/ads.txt updated with real `google.com, pub-..., DIRECT, ...`
#   [ ] AdSense client ID + SLOT_IDS map filled in (after approval)
#   [ ] Google Search Console verification token added + property verified
#   [ ] Google Analytics 4 property created + measurement ID set
# =========================================================================
